# URL canónica (Open Graph, links). Ex. GitHub Pages: https://SEU_USUARIO.github.io/NOME_DO_REPO/
NEXT_PUBLIC_SITE_URL=https://www.wallach.adv.br

# GitHub Project Pages: pasta do site (ex. /site-wallach-assessoria-juridica). Local deixe vazio ou comente.
# NEXT_PUBLIC_BASE_PATH=/site-wallach-assessoria-juridica

# Envio do formulário sem servidor: https://web3forms.com — chave pública, segura no cliente
# NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=

# Sem a chave, o "Enviar" abre o cliente de e-mail (mailto) com a mensagem preenchida.
